<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
                           http://www.springframework.org/schema/beans/spring-beans.xsd">
    <bean id="petrolEngine" class="com.ronak.PetrolEngine" scope="prototype" />
    <bean id="car" class="com.ronak.Car">
        <!--
            - tag used for setter injection
        -->
        <!-- <property name="engine" ref="petrolEngine" /> -->

        <!-- ================================== CONSTRUCTOR INJECTION =================================== -->
        <!--
            - tag used for constructor injection
        -->
        <constructor-arg ref="petrolEngine" name="engine" />
    </bean>
</beans>