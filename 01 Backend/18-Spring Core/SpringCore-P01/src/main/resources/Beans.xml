<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
                           http://www.springframework.org/schema/beans/spring-beans.xsd">

    <bean id="petrolEngine" class="org.cfs.PetrolEngine" />
    <bean id="car" class="org.cfs.Car">
<!--        <property name="engine" ref="petrolEngine" />-->
        <constructor-arg name="engine" ref="petrolEngine" />
    </bean>


    <!-- Revision -->
    <bean id="carEngine" class="org.revise.PetrolEngine" />
    <bean id="reviseCar" class="org.revise.Car">
        <!--
            - inside car pojo require petrolengine reference so put this
            - this is called reference ()
         -->
        <property name="carEngine" ref="carEngine" />
    </bean>
</beans>